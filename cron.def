#####################################################################################
## ISCTE-IUL: Trabalho prático de Sistemas Operativos 2025/2026, Enunciado Versão 1
##
## Aluno: Nº:       Nome:
## Nome do Módulo: S3.2 cron.def
## Descrição/Explicação do Módulo:
##
## Configure sysytem to execute everyday from Monday to Saturday including
## holidays, at 0001h
##
## Cron format:
## minute hour day_of_month month day_of_week command
##
## In this file:
## 1 0 * * 1-6 ./manutencao.sh
## meaning:
## minute = 1
## hour = 0
## day_of_month = * (everyday)
## month = * (each month)
## day_of_week = 1-6 (monday to saturday)
## command = ./manutencao.sh
##
## shell command:
## crontab cron.def
##
#####################################################################################

1 0 * * 1-6 cd "$HOME/trab-2025-parte-1" && ./manutencao.sh